{
  "name": "clauding",
  "owner": {
    "name": "Étienne St-Pierre",
    "email": "me@estpierre.dev"
  },
  "metadata": {
    "description": "A collection of human-in-the-loop interactive prompts for Claude Code, enabling structured, repeatable workflows across diverse tasks and domains.",
    "version": "0.1.0"
  },
  "plugins": [
    {
      "name": "interactive-sdlc",
      "source": "./plugins/interactive-sdlc",
      "description": "[Beta] Interactive SDLC commands for guided development within Claude Code sessions",
      "version": "0.1.0",
      "author": {
        "name": "Étienne St-Pierre",
        "email": "me@estpierre.dev"
      },
      "homepage": "https://github.com/e-stpierre/clauding",
      "repository": "https://github.com/e-stpierre/clauding",
      "license": "MIT",
      "keywords": ["beta", "sdlc", "interactive"],
      "category": "sdlc",
      "strict": false,
      "commands": [
        "./commands/configure.md",
        "./commands/plan/plan-chore.md",
        "./commands/plan/plan-bug.md",
        "./commands/plan/plan-feature.md",
        "./commands/dev/build.md",
        "./commands/dev/validate.md",
        "./commands/dev/document.md",
        "./commands/workflows/one-shot.md",
        "./commands/workflows/plan-build-validate.md",
        "./commands/analyse/analyse-bug.md",
        "./commands/analyse/analyse-doc.md",
        "./commands/analyse/analyse-debt.md",
        "./commands/analyse/analyse-style.md",
        "./commands/analyse/analyse-security.md",
        "./commands/git/git-branch.md",
        "./commands/git/git-commit.md",
        "./commands/git/git-pr.md",
        "./commands/github/create-gh-issue.md",
        "./commands/github/read-gh-issue.md"
      ]
    }
  ]
}
