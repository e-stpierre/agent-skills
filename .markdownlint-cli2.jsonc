{
  "config": {
    "default": true,
    "MD013": false, // Line length
    "MD024": {
      "siblings_only": true // Multiple headings with the same content
    },
    "MD025": {
      "front_matter_title": "" // Don't treat frontmatter title as an h1
    }
  },
  "globs": ["**/*.md"],
  "ignores": ["agentic", "**/node_modules", ".git"]
}
